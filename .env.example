# API Configuration
API_URL=https://api.kognirecovery.com
API_TIMEOUT=30000

# LLM Configuration (OpenAI/Anthropic/etc)
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ENV=development

# Firebase (si se usa para push notifications)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# App Configuration
APP_ENV=development
APP_VERSION=1.0.0
APP_FLAVOR=dev

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false
ENABLE_CHATBOT=true
ENABLE_FAMILY_DASHBOARD=true

# Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
ENCRYPTION_KEY=your_encryption_key_32_chars

# Database (para desarrollo local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kognirecovery_dev
REDIS_URL=redis://localhost:6379

# External Services
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# Emergency Services
EMERGENCY_PHONE=911
EMERGENCY_EMAIL=emergencia@kognirecovery.com