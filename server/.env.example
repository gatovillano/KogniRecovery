# =====================================================
# KogniRecovery - Backend Environment Configuration
# =====================================================
# Copia este archivo a .env y configura los valores
# NO commitees .env al repositorio
# =====================================================

# =====================================================
# SERVER CONFIGURATION
# =====================================================
NODE_ENV=development
PORT=3002
API_URL=http://localhost:3002
API_VERSION=v1

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kognirecovery_dev

# Database pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000

# =====================================================
# JWT CONFIGURATION
# =====================================================
# Tokens de acceso (short-lived)
JWT_SECRET=your_jwt_secret_key_min_32_chars_here_change_in_production
JWT_EXPIRES_IN=15m

# Refresh tokens (long-lived)
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# =====================================================
# AUTH CONFIGURATION
# =====================================================
# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Session configuration
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15
TOKEN_ROTATION_ENABLED=true

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ORIGIN=http://localhost:8081
CORS_ORIGIN_WEB=http://localhost:19006
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth endpoint rate limits
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=60000

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# =====================================================
# EXTERNAL SERVICES (optional)
# =====================================================
# Redis for session storage (optional)
REDIS_URL=redis://localhost:6379

# Email service (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@kognirecovery.com

# =====================================================
# SECURITY
# =====================================================
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your_encryption_key_32_chars_minimum

# =====================================================
# APPLICATION SPECIFIC
# =====================================================
APP_NAME=KogniRecovery
APP_URL=http://localhost:19006
SUPPORT_EMAIL=soporte@kognirecovery.com
EMERGENCY_PHONE=911
