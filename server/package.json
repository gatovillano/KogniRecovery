{
  "name": "kognirecovery-server",
  "version": "1.0.0",
  "description": "Backend API for KogniRecovery - Sistema de Acompañamiento en Adicciones",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "keywords": [
    "kognirecovery",
    "addiction-recovery",
    "mental-health",
    "express",
    "postgresql",
    "jwt"
  ],
  "author": "KogniRecovery Team",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.36",
    "neo4j-driver": "^6.0.1",
    "openai": "^6.25.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.11.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}